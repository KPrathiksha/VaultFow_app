<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="VaultFlow Selenium Automation Suite" parallel="methods" thread-count="4">
  <listeners>
    <listener class-name="com.vaultflow.listeners.TestListener"/>
    <listener class-name="com.vaultflow.listeners.RetryTransformer"/>
  </listeners>
  <test name="VaultFlow Portfolio Regression">
    <classes>
      <class name="com.vaultflow.tests.VaultFlowPortfolioTest"/>
    </classes>
  </test>
</suite>
